// Prisma Schema — Luxury Invoice Declaration Platform
// Phase 1: Auth, Users, Organizations, KYC/KYB, Invite Codes
// Phase 2: Invoice upload, OCR, fraud scoring

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN        // Internal platform admin
  REVIEWER     // Internal human reviewer
  ORG_ADMIN    // Organization account manager
  RESELLER     // Individual reseller
}

enum AccountType {
  INDIVIDUAL   // Standalone reseller with own KYB
  ORGANIZATION // Business entity; resellers link under it
}

enum KycStatus {
  NOT_STARTED
  PENDING
  APPROVED
  FAILED
  EXPIRING    // Document expiring within 30 days
  EXPIRED
}

enum KybStatus {
  NOT_STARTED
  PENDING
  APPROVED
  FAILED
  EXPIRING
  EXPIRED
}

enum UserStatus {
  REGISTERED    // Email verified, KYC not yet started
  KYC_PENDING
  ACTIVE
  SUSPENDED
  BLACKLISTED
}

enum InviteCodeStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum InvoiceStatus {
  PENDING_UPLOAD    // Presigned URL issued, file not yet confirmed
  UPLOADED          // S3 confirmed, OCR queued
  OCR_PROCESSING    // Google Document AI running
  OCR_DONE          // OCR complete, fraud check queued
  FRAUD_REVIEW      // Flagged for human review
  APPROVED          // Cashback eligible
  REJECTED          // Rejected — reseller notified
  BLACKLISTED       // Invoice blacklisted (fraud confirmed)
}

enum InvoiceCurrency {
  EUR
  USD
  GBP
  CNY
  JPY
  CHF
}

// ─────────────────────────────────────────────
// ORGANIZATION
// An org has one KYB; its resellers each do KYC only
// ─────────────────────────────────────────────

model Organization {
  id            String     @id @default(uuid())
  name          String
  registrationNo String?   // Business registration number
  country       String     @default("FR")
  kybStatus     KybStatus  @default(NOT_STARTED)
  diditKybSessionId String? // Didit session ID for KYB

  // Cashback configuration
  cashbackRate  Decimal    @default(0) @db.Decimal(5, 4) // e.g. 0.0300 = 3%

  members       User[]
  invoices      Invoice[]
  inviteCodes   InviteCode[]
  auditLogs     AuditLog[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?  // Soft delete for GDPR

  @@map("organizations")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  locale        String      @default("fr") // fr | en | zh
  role          UserRole    @default(RESELLER)
  status        UserStatus  @default(REGISTERED)
  accountType   AccountType @default(INDIVIDUAL)

  // Registration path
  registeredViaInvite Boolean @default(false)

  // KYC (all users who are resellers)
  kycStatus     KycStatus   @default(NOT_STARTED)
  diditKycSessionId String?
  kycDocumentExpiresAt DateTime?

  // KYB (only INDIVIDUAL resellers, not org-linked resellers)
  kybStatus     KybStatus   @default(NOT_STARTED)
  diditKybSessionId String?
  kybDocumentExpiresAt DateTime?

  // Cashback (for individuals not under an org)
  cashbackRate  Decimal?    @db.Decimal(5, 4)

  // Org link (nullable — only for ORG_ADMIN and org resellers)
  organizationId String?
  organization  Organization? @relation(fields: [organizationId], references: [id])

  // Auth
  refreshTokenHash String?
  emailVerifiedAt  DateTime?
  emailVerificationToken String? @unique
  passwordResetToken     String? @unique
  passwordResetExpiresAt DateTime?
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?   // encrypted TOTP secret

  // GDPR
  gdprConsentAt DateTime?
  marketingConsent Boolean @default(false)

  // Sessions & activity
  lastLoginAt   DateTime?
  lastLoginIp   String?

  invoices      Invoice[]
  auditLogs     AuditLog[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?  // Soft delete — data kept per retention policy

  @@map("users")
}

// ─────────────────────────────────────────────
// INVITE CODE
// Generated by admin or org admin; reseller self-registers with it
// ─────────────────────────────────────────────

model InviteCode {
  id              String           @id @default(uuid())
  code            String           @unique
  status          InviteCodeStatus @default(ACTIVE)
  intendedRole    UserRole         @default(RESELLER)
  intendedOrgId   String?          // If set, new user is linked to this org
  organization    Organization?    @relation(fields: [intendedOrgId], references: [id])
  createdByUserId String           // Admin or org admin who generated it
  usedByUserId    String?          // Filled when code is consumed
  expiresAt       DateTime
  usedAt          DateTime?

  createdAt       DateTime         @default(now())

  @@map("invite_codes")
}

// ─────────────────────────────────────────────
// INVOICE — full Phase 2 model
// ─────────────────────────────────────────────

model Invoice {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  organizationId String?
  organization  Organization?   @relation(fields: [organizationId], references: [id])

  // File storage
  s3Key         String?         // Object key in S3 (e.g. invoices/{userId}/{uuid}.pdf)
  s3Bucket      String?
  originalFilename String?
  mimeType      String?         // application/pdf | image/jpeg | image/png
  fileSizeBytes Int?

  // Status machine
  status        InvoiceStatus   @default(PENDING_UPLOAD)

  // OCR-extracted fields (nullable until OCR completes)
  invoiceNumber     String?
  purchaseDate      DateTime?
  vendorName        String?
  vendorAddress     String?
  brandName         String?     // e.g. "Chanel", "Louis Vuitton"
  storeLocation     String?     // e.g. "Chanel Boutique Printemps Haussmann"
  itemDescription   String?
  itemCategory      String?     // e.g. "handbag", "watch", "jewellery"
  currency          InvoiceCurrency?
  subtotalAmount    Decimal?    @db.Decimal(12, 2)
  taxAmount         Decimal?    @db.Decimal(12, 2)
  grandTotalAmount  Decimal?    @db.Decimal(12, 2)
  cashbackAmount    Decimal?    @db.Decimal(12, 2) // calculated after approval

  // OCR confidence / quality
  ocrConfidence     Float?      // 0.0 – 1.0 overall confidence from Document AI
  ocrRawJson        Json?       // full Document AI response (retained for audit)

  // Fraud scoring
  fraudScore        Float?      // 0.0 = clean, 1.0 = definite fraud
  fraudFlags        Json?       // array of triggered rule names
  reviewNote        String?     // reviewer's free-text note

  // Timestamps
  uploadedAt    DateTime?
  ocrCompletedAt DateTime?
  reviewedAt    DateTime?
  reviewedById  String?

  deletedAt     DateTime?       // GDPR soft delete

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([purchaseDate])
  @@index([vendorName])
  @@map("invoices")
}

// ─────────────────────────────────────────────
// MERCHANT BILL — imported from department store official billing data
// Used for reconciliation (Module C)
// ─────────────────────────────────────────────

model MerchantBill {
  id           String   @id @default(uuid())
  merchantName String               // e.g. "Galeries Lafayette", "Printemps"
  date         DateTime @db.Date    // billing date (day-level granularity)
  totalAmount  Decimal  @db.Decimal(12, 2) // official total billed for that day
  importedAt   DateTime @default(now())

  @@unique([merchantName, date])
  @@index([merchantName])
  @@index([date])
  @@map("merchant_bills")
}

// ─────────────────────────────────────────────
// AUDIT LOG — immutable event trail (GDPR Art.5(2))
// ─────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  actorId        String?  // null = system
  actorRole      String?
  action         String   // e.g. "USER_LOGIN", "KYC_STATUS_CHANGED"
  resourceType   String   // e.g. "User", "Invoice"
  resourceId     String?
  meta           Json?    // extra context, sanitized
  ipAddress      String?  // anonymized after 30d via scheduled job
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt      DateTime @default(now())

  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}
