generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                String       @id @default(uuid())
  name              String
  registrationNo    String?
  country           String       @default("FR")
  kybStatus         KybStatus    @default(NOT_STARTED)
  cashbackRate      Decimal      @default(0) @db.Decimal(5, 4)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?
  diditKybSessionId String?
  auditLogs         AuditLog[]
  inviteCodes       InviteCode[]
  invoices          Invoice[]
  members           User[]

  @@map("organizations")
}

model User {
  id                     String        @id @default(uuid())
  email                  String        @unique
  passwordHash           String
  firstName              String
  lastName               String
  phone                  String?
  locale                 String        @default("fr")
  role                   UserRole      @default(RESELLER)
  status                 UserStatus    @default(REGISTERED)
  accountType            AccountType   @default(INDIVIDUAL)
  kycStatus              KycStatus     @default(NOT_STARTED)
  kycDocumentExpiresAt   DateTime?
  kybStatus              KybStatus     @default(NOT_STARTED)
  kybDocumentExpiresAt   DateTime?
  cashbackRate           Decimal?      @db.Decimal(5, 4)
  organizationId         String?
  refreshTokenHash       String?
  emailVerifiedAt        DateTime?
  emailVerificationToken String?       @unique
  passwordResetToken     String?       @unique
  passwordResetExpiresAt DateTime?
  mfaEnabled             Boolean       @default(false)
  mfaSecret              String?
  gdprConsentAt          DateTime?
  marketingConsent       Boolean       @default(false)
  lastLoginAt            DateTime?
  lastLoginIp            String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  deletedAt              DateTime?
  diditKybSessionId      String?
  diditKycSessionId      String?
  registeredViaInvite    Boolean       @default(false)
  kycDocumentKey         String?
  auditLogs              AuditLog[]
  invoices               Invoice[]
  organization           Organization? @relation(fields: [organizationId], references: [id])

  @@map("users")
}

model InviteCode {
  id              String           @id @default(uuid())
  code            String           @unique
  status          InviteCodeStatus @default(ACTIVE)
  intendedRole    UserRole         @default(RESELLER)
  intendedOrgId   String?
  createdByUserId String
  usedByUserId    String?
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime         @default(now())
  organization    Organization?    @relation(fields: [intendedOrgId], references: [id])

  @@map("invite_codes")
}

model Invoice {
  id                String           @id @default(uuid())
  userId            String
  organizationId    String?
  s3Key             String?
  s3Bucket          String?
  originalFilename  String?
  mimeType          String?
  fileSizeBytes     Int?
  status            InvoiceStatus    @default(PENDING)
  invoiceNumber     String?
  purchaseDate      DateTime?
  vendorName        String?
  vendorAddress     String?
  brandName         String?
  storeLocation     String?
  itemDescription   String?
  itemCategory      String?
  currency          InvoiceCurrency?
  subtotalAmount    Decimal?         @db.Decimal(12, 2)
  taxAmount         Decimal?         @db.Decimal(12, 2)
  grandTotalAmount  Decimal?         @db.Decimal(12, 2)
  cashbackAmount    Decimal?         @db.Decimal(12, 2)
  ocrConfidence     Float?
  ocrRawJson        Json?
  fraudFlags        Json?
  reviewNote        String?
  uploadedAt        DateTime?
  ocrCompletedAt    DateTime?
  reviewedAt        DateTime?
  reviewedById      String?
  deletedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  arithmeticCheck   String?
  lineItems         Json?
  needsReview       Boolean          @default(false)
  reviewReasons     String[]
  taxRefundAmount   Decimal?         @db.Decimal(12, 2)
  cashbackBreakdown Json?
  organization      Organization?    @relation(fields: [organizationId], references: [id])
  user              User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([purchaseDate])
  @@index([vendorName])
  @@map("invoices")
}

model MerchantCashbackConfig {
  id            String              @id @default(uuid())
  merchantKey   String              @unique
  displayName   String
  matchKeywords String[]            @default([])
  defaultRate   Decimal             @default(0) @db.Decimal(5, 4)
  notes         String?
  isActive      Boolean             @default(true)
  sortOrder     Int                 @default(0)
  updatedAt     DateTime            @updatedAt
  createdAt     DateTime            @default(now())
  brandRules    BrandCashbackRule[]

  @@map("merchant_cashback_configs")
}

model BrandCashbackRule {
  id           String                 @id @default(uuid())
  merchantId   String
  displayLabel String
  brands       String[]               @default([])
  rate         Decimal                @default(0) @db.Decimal(5, 4)
  condition    String?
  sortOrder    Int                    @default(0)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  merchant     MerchantCashbackConfig @relation(fields: [merchantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("brand_cashback_rules")
}

model MerchantBill {
  id           String   @id @default(uuid())
  merchantName String
  date         DateTime @db.Date
  totalAmount  Decimal  @db.Decimal(12, 2)
  importedAt   DateTime @default(now())

  @@unique([merchantName, date])
  @@index([merchantName])
  @@index([date])
  @@map("merchant_bills")
}

model AuditLog {
  id             String        @id @default(uuid())
  actorId        String?
  actorRole      String?
  action         String
  resourceType   String
  resourceId     String?
  meta           Json?
  ipAddress      String?
  userId         String?
  organizationId String?
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum UserRole {
  ADMIN
  REVIEWER
  ORG_ADMIN
  RESELLER
}

enum AccountType {
  INDIVIDUAL
  ORGANIZATION
}

enum KycStatus {
  NOT_STARTED
  PENDING
  APPROVED
  FAILED
  EXPIRING
  EXPIRED
}

enum KybStatus {
  NOT_STARTED
  PENDING
  APPROVED
  FAILED
  EXPIRING
  EXPIRED
}

enum UserStatus {
  REGISTERED
  KYC_PENDING
  ACTIVE
  SUSPENDED
  BLACKLISTED
}

enum InviteCodeStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum InvoiceStatus {
  PENDING
  APPROVED
  REJECTED
  UPLOADED
  OCR_PROCESSING
  OCR_DONE
}

enum InvoiceCurrency {
  EUR
  USD
  GBP
  CNY
  JPY
  CHF
}
