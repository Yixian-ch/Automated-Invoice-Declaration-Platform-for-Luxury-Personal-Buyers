# Application
NODE_ENV=production
PORT=3001

# Database — docker-compose 会自动覆盖此值，保持格式即可
DATABASE_URL="postgresql://lidp:CHANGE_ME@postgres:5432/lidp_db"

# Redis — docker-compose 会自动覆盖此值
REDIS_URL="redis://redis:6379"

# JWT — 生成命令: openssl rand -base64 32
JWT_SECRET="CHANGE_ME"
JWT_EXPIRY="15m"
JWT_REFRESH_SECRET="CHANGE_ME"
JWT_REFRESH_EXPIRY="7d"

# KYC/Email
BYPASS_KYC=false
BYPASS_EMAIL_VERIFICATION=false

# OCR
BYPASS_OCR=false
OCR_SERVICE_URL=http://localhost:8001

# AWS S3
AWS_REGION="eu-west-3"
AWS_ACCESS_KEY_ID="CHANGE_ME"
AWS_SECRET_ACCESS_KEY="CHANGE_ME"
AWS_S3_BUCKET="lidp-documents-prod"
BYPASS_S3=false

# URLs
FRONTEND_URL="https://ruichi.online"
APP_URL="https://ruichi.online"
API_URL="https://ruichi.online/api"

# Email (Resend)
MAIL_FROM="LIDP <onboarding@resend.dev>"
RESEND_API_KEY="CHANGE_ME"

# Invite
INVITE_CODE_EXPIRY_HOURS=72

# Mistral OCR
MISTRAL_API_KEY="CHANGE_ME"
